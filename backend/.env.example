# InkGrid 后端环境变量示例
# 复制为 .env 并按需修改：cp .env.example .env

# ===== 应用 =====
APP_NAME=InkGrid
DEBUG=true
API_PREFIX=/api

# ===== 站点 =====
SITE_NAME=inkgrid.dev
SITE_AUTHOR=博主
SITE_VERSION=v1.0.0

# ===== 数据库（PostgreSQL） =====
DATABASE_URL=postgresql+asyncpg://inkgrid:inkgrid@localhost:5432/inkgrid

# ===== Redis（限流 + Celery broker） =====
REDIS_URL=redis://localhost:6379/0

# ===== 鉴权 =====
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24
COOKIE_NAME=admin_token

# ===== 限流 =====
RATE_LIMIT_IP_PER_MIN=60
RATE_LIMIT_CHAT_IP_PER_MIN=20
RATE_LIMIT_CHAT_ANON_PER_DAY=50

# ===== Next.js =====
NEXT_REVALIDATE_TOKEN=inkgrid-dev-revalidate-secret
NEXT_PUBLIC_API_BASE=http://localhost:3000

# ===== CORS 额外 origin(局域网联调) =====
# 填开发机 IP,多个用逗号分隔;留空则只允许 localhost
# 示例:CORS_EXTRA_ORIGINS=http://192.168.1.37:3000
CORS_EXTRA_ORIGINS=

# ===== 对象存储（MinIO） =====
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
MINIO_BUCKET=inkgrid
MINIO_SECURE=false

# ===== LLM 网关（OpenAI 兼容） =====
# 开发期（LMStudio 本地）：
#   1. LMStudio 加载 qwen2.5-7b-instruct GGUF 模型
#   2. 开启 Local Server（端口 1234），勾选 "Serve OpenAI-compatible API"
#   3. API_KEY 任意值即可
# 生产期（通义/DeepSeek）：
#   通义：LLM_PROVIDER=qwen, LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#   DeepSeek：LLM_PROVIDER=deepseek, LLM_BASE_URL=https://api.deepseek.com/v1
LLM_PROVIDER=lmstudio
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio
LLM_MODEL=qwen2.5-7b-instruct
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048
LLM_REQUEST_TIMEOUT=60

# ===== Embedding（BGE-M3） =====
# 双模式：配了 EMBEDDING_TEI_URL 用 TEI 服务，否则进程内 sentence-transformers 加载
# 进程内首次会从 HuggingFace 自动下载模型（约 1.2GB）到 EMBEDDING_CACHE_DIR
# 国内可设置 HF_ENDPOINT=https://hf-mirror.com 加速
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_CACHE_DIR=./models
EMBEDDING_BATCH_SIZE=16
EMBEDDING_TEI_URL=http://localhost:8080

# ===== Reranker（bge-reranker-v2-m3） =====
# 双模式：配了 RERANKER_TEI_URL 用 TEI 服务，否则进程内 sentence-transformers 加载
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_DEVICE=cpu
RERANKER_CACHE_DIR=./models
RERANKER_TOP_N=5
RERANKER_TEI_URL=http://localhost:8081

# ===== Milvus 向量库 =====
# 开发期：docker compose up milvus（见 docker-compose.dev.yml）
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=inkgrid_chunks
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_USE_PARTITION=true

# ===== HuggingFace 镜像（可选，加速模型下载） =====
# HF_ENDPOINT=https://hf-mirror.com
