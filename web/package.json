{
  "name": "inkgrid-web",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "dev:local": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "electron:dev": "cross-env ELECTRON_DEV=1 NEXT_PUBLIC_API_BASE=http://localhost:8000/api concurrently -k -n next,electron -c cyan,magenta \"next dev -p 3000\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "dotenv -e .env.electron -- next build && electron-builder --win",
    "electron:start": "cross-env NEXT_PUBLIC_API_BASE=http://localhost:8000/api electron .",
    "electron:pack": "dotenv -e .env.electron -- next build && electron-builder --dir --win"
  },
  "dependencies": {
    "@ant-design/icons": "^5.4.0",
    "@ant-design/nextjs-registry": "^1.0.0",
    "@bytemd/plugin-gfm": "^1.21.0",
    "@bytemd/plugin-highlight": "^1.21.0",
    "@bytemd/plugin-math": "^1.21.0",
    "@bytemd/plugin-mermaid": "^1.21.0",
    "@bytemd/react": "^1.21.0",
    "@tanstack/react-query": "^5.101.4",
    "antd": "^5.20.0",
    "axios": "^1.7.3",
    "bytemd": "^1.21.0",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.12",
    "geist": "^1.7.2",
    "github-slugger": "^2.0.0",
    "highlight.js": "^11.11.1",
    "katex": "^0.18.1",
    "lucide-react": "^0.427.0",
    "meilisearch": "^0.41.0",
    "next": "14.2.5",
    "next-mdx-remote": "^5.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shiki": "^1.12.1",
    "unist-util-visit": "^5.1.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/node": "^20.14.15",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.4",
    "wait-on": "^9.1.0"
  }
}
